# LLM provider configuration
# For Ollama (local dev) — use ollama_chat/ prefix for chat models:
BROKE_MODEL=ollama_chat/llama3.1
BROKE_LLM_BASE_URL=http://127.0.0.1:11434
# For LM Studio (local dev):
# BROKE_MODEL=openai/local-model
# BROKE_LLM_BASE_URL=http://localhost:1234/v1
# For OpenAI (prod):
# BROKE_MODEL=openai/gpt-4o
# OPENAI_API_KEY=sk-...

# Embedding model (sentence-transformers, runs locally)
BROKE_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ChromaDB persistence
BROKE_CHROMA_PATH=./chroma_data

# Conversation memory
BROKE_MEMORY_WINDOW=20

# Debug mode (shows agent routing, specialist results)
BROKE_DEBUG=false
